{
  "name": "@unstop-agent/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/server.js",
    "scrape": "tsx src/scrape-once.ts",
    "db:generate": "prisma generate",
    "db:migrate": "tsx src/db/init.ts && prisma generate",
    "db:init": "tsx src/db/init.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/static": "^9.1.3",
    "@prisma/client": "^6.19.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "leetcode-query": "^2.0.1",
    "node-cron": "^4.2.1",
    "resend": "^6.15.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "prisma": "^6.19.0",
    "tsx": "^4.20.6"
  }
}
