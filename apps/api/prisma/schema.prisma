generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id          String   @id
  sourceId    String   @default("unstop")
  title       String
  company     String
  location    String?
  jobType     String?
  timing      String?
  applyUrl    String
  postedAt    DateTime?
  deadline    DateTime?
  firstSeenAt DateTime @default(now())
  isNew       Boolean  @default(true)
  raw         String

  @@index([isNew])
  @@index([sourceId])
  @@index([firstSeenAt])
  @@index([deadline])
}

model Source {
  id      String  @id
  label   String
  type    String
  enabled Boolean @default(true)
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  createdAt   DateTime @default(now())
  lastLoginAt DateTime @default(now())

  preferences UserSourcePreference[]
  reminders   ContestReminder[]
  magicTokens MagicLoginToken[]

  @@index([email])
}

model MagicLoginToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  email     String
  userId    String?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([expiresAt])
}

model Contest {
  id          String   @id
  site        String
  name        String
  url         String
  startTime   DateTime
  durationSec Int
  firstSeenAt DateTime @default(now())
  isNew       Boolean  @default(true)
  raw         String

  reminders ContestReminder[]

  @@index([site])
  @@index([isNew])
  @@index([startTime])
  @@index([firstSeenAt])
}

model UserSourcePreference {
  id           String  @id @default(uuid())
  userId       String
  sourceId     String
  visible      Boolean @default(true)
  emailEnabled Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceId])
  @@index([userId])
  @@index([sourceId])
}

model ContestReminder {
  id        String    @id @default(uuid())
  userId    String
  contestId String
  notifyAt  DateTime
  createdAt DateTime  @default(now())
  notifiedAt DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@unique([userId, contestId])
  @@index([notifyAt])
  @@index([notifiedAt])
}

model ScrapeRun {
  id           Int       @id @default(autoincrement())
  status       String
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  jobsFound    Int       @default(0)
  jobsInserted Int       @default(0)
  errorMessage String?

  @@index([startedAt])
}
